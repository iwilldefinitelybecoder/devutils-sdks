# DevUtils SDK Configuration

# API Configuration
DEVUTILS_API_KEY=your-api-key-here
DEVUTILS_BASE_URL=https://api.devutils.in
DEVUTILS_TIMEOUT=30000

# Development
NODE_ENV=development
DEBUG=false

# Python SDK
PYTHONPATH=.

# Optional: AWS S3 for CDN uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Optional: Slack notifications
SLACK_WEBHOOK=
